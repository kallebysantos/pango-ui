@namespace Pango.Components.UI
@inherits UIComponent

<button @attributes='@AdditionalAttributes' class='@Tw(
    "group inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium", 
    "transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring",
    "disabled:pointer-events-none disabled:opacity-50",
    ButtonVariants[Variant],
    ButtonSizes[Size],
    AdditionalAttributes?.GetValueOrDefault("class") ?? string.Empty
)'>
    @ChildContent
</button>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}